<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net35</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AssemblyName>FTK MultiMax Rework v2</AssemblyName>
    <RootNamespace>FTK_MultiMax_Rework_v2</RootNamespace>
    <Version>2.1.0</Version>
    <Authors>Polars Bear (upon work by justedm &amp; samupo)</Authors>
    <Description>A few patches and bugfixes on justedm's MultiMax Rework.</Description>

    <!-- Suppress auto-generated AssemblyInfo since we removed it -->
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  </PropertyGroup>

  <!-- Game and mod-loader DLLs — override via Directory.Build.props or /p: flags -->
  <PropertyGroup>
    <FTKGamePath Condition="'$(FTKGamePath)' == ''">$(HOME)\..\..\..\Program Files (x86)\Steam\steamapps\common\For The King\FTK_Data\Managed</FTKGamePath>
    <BepInExPath Condition="'$(BepInExPath)' == ''">$(HOME)\AppData\Roaming\r2modmanPlus-local\ForTheKing\profiles\Default\BepInEx\core</BepInExPath>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="0Harmony">
      <HintPath>$(BepInExPath)\0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BepInEx">
      <HintPath>$(BepInExPath)\BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(FTKGamePath)\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Assembly-CSharp-firstpass">
      <HintPath>$(FTKGamePath)\Assembly-CSharp-firstpass.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Rewired_Core">
      <HintPath>$(FTKGamePath)\Rewired_Core.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>$(FTKGamePath)\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(FTKGamePath)\UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UI">
      <HintPath>$(FTKGamePath)\UnityEngine.UI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UIModule">
      <HintPath>$(FTKGamePath)\UnityEngine.UIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="PackageResources\**" />
  </ItemGroup>

</Project>
